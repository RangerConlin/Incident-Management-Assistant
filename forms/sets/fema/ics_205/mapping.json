{
  "description": "ICS 205 - Radio Communications Plan - FEMA ICS Forms 2023",
  "fields": [
    {
      "pdf_field": "1 Incident Name_8",
      "source": "incident.name"
    },
    {
      "pdf_field": "2 Date/Time Prepared",
      "source": {
        "join": [
          "prepared_by.name",
          "prepared_by.date_time"
        ],
        "separator": ", "
      }
    },
    {
      "pdf_field": "Date From",
      "source": {
        "key": "op_period.start",
        "transform": "date_short"
      }
    },
    {
      "pdf_field": "Date To",
      "source": {
        "key": "op_period.end",
        "transform": "date_short"
      }
    },
    {
      "pdf_field": "Time From",
      "source": {
        "key": "op_period.start",
        "transform": "time_short"
      }
    },
    {
      "pdf_field": "Time To",
      "source": {
        "key": "op_period.end",
        "transform": "time_short"
      }
    },
    {
      "pdf_field": "5 Special Instructions",
      "source": {
        "key": "channels_notes",
        "default": ""
      }
    },
    {
      "pdf_field": "6 Prepared by Communications Unit Leader Name",
      "source": "organization.communications_unit_leader.name"
    },
    {
      "pdf_field": "IAP Page_4",
      "source": {
        "literal": ""
      }
    },
    {
      "pdf_field": "DateTime_8",
      "source": "prepared_by.date_time"
    },
    {
      "pdf_field": "Signature_9",
      "source": {
        "literal": ""
      }
    }
  ],
  "row_groups": [
    {
      "ref": "radio_channels",
      "data_key": "channels",
      "overflow_mode": "truncate",
      "rows_per_page": [
        8
      ],
      "col_patterns": {
        "band": "Zone GrpRow{n}",
        "id": "Ch Row{n}",
        "function": "function{n}",
        "name": "name{n}",
        "assignment": "assignment{n}",
        "rx_freq": "rx_freq{n}",
        "rx_tone": "rx_tone{n}",
        "tx_freq": "tx_freq{n}",
        "tx_tone": "tx_tone{n}",
        "mode": "mode{n}",
        "remarks": "remarks{n}"
      }
    }
  ]
}
