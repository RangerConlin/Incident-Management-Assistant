{
  "description": "SAR 110 - Team Debriefing (Ground)",
  "fields": [
    { "pdf_field": "incident.name", "source": "incident.name" },
    { "pdf_field": "operational.period", "source": "op_period.number" },
    { "pdf_field": "assignment.number", "source": { "first_of": ["debrief.sortie_number", "tasks.0.task_id"] } },
    { "pdf_field": "resource_type", "source": "teams.0.resource_type" },
    { "pdf_field": "assignment_summary", "source": "debrief.ground.assignment_summary" },
    { "pdf_field": "search_efforts", "source": "debrief.ground.efforts" },
    { "pdf_field": "unsearched", "source": "debrief.ground.unable" },
    { "pdf_field": "clues", "source": "debrief.ground.clues" },
    { "pdf_field": "hazards", "source": "debrief.ground.hazards" },
    { "pdf_field": "sugestions", "source": "debrief.ground.suggestions" },
    { "pdf_field": "time_in", "source": "debrief.ground.time_entered" },
    { "pdf_field": "time_out", "source": "debrief.ground.time_exited" },
    { "pdf_field": "search_time", "source": "debrief.ground.time_spent" },
    { "pdf_field": "debriefer", "source": "debrief.debriefer_id" },
    { "pdf_field": "debrief_datetime", "source": { "key": "debrief.created_at", "transform": "datetime_short" } },

    { "pdf_field": "POD.h.responsive", "source": "assignment.ground.expected_pod.responsive.high" },
    { "pdf_field": "POD.h.unresponsive", "source": "assignment.ground.expected_pod.unresponsive.high" },
    { "pdf_field": "POD.h.clues", "source": "assignment.ground.expected_pod.clues.high" },
    { "pdf_field": "POD.m.responsive", "source": "assignment.ground.expected_pod.responsive.medium" },
    { "pdf_field": "POD.m.unresponsive", "source": "assignment.ground.expected_pod.unresponsive.medium" },
    { "pdf_field": "POD.m.clues", "source": "assignment.ground.expected_pod.clues.medium" },
    { "pdf_field": "POD.l.responsive", "source": "assignment.ground.expected_pod.responsive.low" },
    { "pdf_field": "POD.l.unresponsive", "source": "assignment.ground.expected_pod.unresponsive.low" },
    { "pdf_field": "POD.l.clues", "source": "assignment.ground.expected_pod.clues.low" },

    { "pdf_field": "attachments.maps", "source": { "key": "debrief.ground.att_map", "checkbox": true, "checked_value": "X", "unchecked_value": "" } },
    { "pdf_field": "attachments.briefing", "source": { "key": "debrief.ground.att_brief", "checkbox": true, "checked_value": "X", "unchecked_value": "" } },
    { "pdf_field": "attachments.supplemental", "source": { "key": "debrief.ground.att_supp", "checkbox": true, "checked_value": "X", "unchecked_value": "" } },
    { "pdf_field": "attachments.other", "source": { "key": "debrief.ground.att_other", "checkbox": true, "checked_value": "X", "unchecked_value": "" } }
  ]
}
