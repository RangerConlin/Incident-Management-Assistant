    {"pdf_field": "Channel1Tone", "source": {"key": "communications.channels.0.tone", "default": "CSQ"}},
    {"pdf_field": "Channel2Function", "source": {"literal": "Tactical"}},
    {"pdf_field": "Channel2Assignment", "source": {"key": "communications.channels.1.assignment", "default": "Division A"}},
    {"pdf_field": "Channel2Frequency", "source": {"key": "communications.channels.1.frequency", "default": "TBD"}},
    {"pdf_field": "Channel2Tone", "source": {"key": "communications.channels.1.tone", "default": "CSQ"}},
    {"pdf_field": "PreparedBy", "source": {"join": ["preparer.first_name", "preparer.last_name"], "separator": " ", "default": "COML"}},
